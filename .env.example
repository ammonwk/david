# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/david

# Target repository
TARGET_REPO_URL=git@github.com:AiAutomatrix/ai-outbound-agent.git
REPO_CONTROL_DIR=~/.david/repo-control
BASE_BRANCH=staging

# AWS
AWS_REGION=us-east-1
CLOUDWATCH_LOG_GROUP=/ecs/sms-agent
ECS_CLUSTER_NAME=sms-agent
ECS_SERVICE_NAME=sms-agent

# GitHub
GITHUB_TOKEN=
GITHUB_OWNER=AiAutomatrix
GITHUB_REPO=ai-outbound-agent

# OpenRouter (for codebase mapping via Gemini)
OPENROUTER_API_KEY=

# Agent pool (optional — defaults shown)
# MAX_CONCURRENT_AGENTS=30
# AGENT_TIMEOUT_MS=3600000
# AGENT_MAX_RESTARTS=3

# CLI backend (optional — switch to codex to run OpenAI Codex CLI instead of Claude Code)
# CLI_BACKEND=claude

# Claude CLI (optional — defaults to 'claude' on PATH)
# CLAUDE_BINARY=claude

# Codex CLI (optional — defaults to 'codex' on PATH; only used when CLI_BACKEND=codex)
# CODEX_BINARY=codex
